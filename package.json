    "tabby-core": "*",
    "tabby-settings": "*",
    "tabby-ssh": "*"
  },
  "devDependencies": {
    "@angular/common": "^15.0.0",
    "@angular/core": "^15.0.0",
    "@angular/forms": "^15.0.0",
    "@types/node": "^20.0.0",
    "raw-loader": "^4.0.2",
    "ts-loader": "^9.5.1",
    "typescript": "~4.9.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
