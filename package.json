  "license": "MIT",
  "keywords": [
    "tabby-plugin",
    "tabby",
    "keepass",
    "ssh",
    "totp",
    "mfa",
    "2fa",
    "password-manager"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/search5/tabby-ssh-keepass.git"
  },
  "bugs": {
    "url": "https://github.com/search5/tabby-ssh-keepass/issues"
  },
  "homepage": "https://github.com/search5/tabby-ssh-keepass#readme",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "scripts/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "webpack",
    "watch": "webpack --watch",
    "install-plugin": "node scripts/install-plugin.js",
    "link": "bash scripts/link-plugin.sh",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "argon2-browser": "^1.18.0",
    "hash-wasm": "^4.12.0",
